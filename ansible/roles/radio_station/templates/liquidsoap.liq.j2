# Radio station — generated by Ansible, do not edit by hand

settings.server.telnet := true
settings.server.telnet.bind_addr := "0.0.0.0"
settings.server.telnet.port := 1234

# On-demand request queue (highest priority)
requests = request.queue(id="requests")

# Background playlist managed by radio-service (/data/background.m3u)
# reload_mode="watch" picks up file changes immediately via inotify
background = playlist(
  id="background",
  mode="randomize",
  reload_mode="watch",
  "/data/background.m3u"
)

# Fallback chain: queued requests → background playlist
radio = fallback(id="radio", track_sensitive=true, [requests, background])

# Push track-change events to radio-service (runs in a separate thread
# so HTTP I/O doesn't block the audio pipeline)
def on_track(m) =
  title    = m["title"]
  artist   = m["artist"]
  album    = m["album"]
  filename = m["filename"]
  def do_notify() =
    data =
      "title="    ^ url.encode(title)    ^
      "&artist="  ^ url.encode(artist)   ^
      "&album="   ^ url.encode(album)    ^
      "&filename=" ^ url.encode(filename)
    ignore(
      http.post(
        "http://localhost:8081/internal/track-changed",
        headers=[("Content-Type", "application/x-www-form-urlencoded")],
        data=data
      )
    )
  end
  ignore(thread.run(fast=false, do_notify))
end

radio = on_metadata(on_track, radio)

# Icecast output
output.icecast(
  %mp3(bitrate={{ radio_station_stream_bitrate }}),
  host="localhost",
  port=8000,
  password="{{ radio_station_icecast_source_password }}",
  mount="{{ radio_station_stream_mount }}",
  name="{{ radio_station_stream_name }}",
  description="{{ radio_station_stream_description }}",
  radio
)
