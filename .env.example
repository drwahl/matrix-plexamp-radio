# Copy to .env and fill in your values
# cp .env.example .env

# ── Paths ─────────────────────────────────────────────────────────────────────
RADIO_WEB_PORT=8080
MUSIC_PATH=/path/to/your/music

# ── Stream ────────────────────────────────────────────────────────────────────
STREAM_NAME=My Radio
STREAM_DESCRIPTION=Personal radio stream
STREAM_BITRATE=320
STREAM_MOUNT=/stream
# Public-facing stream URL shown in the bot greeting.
# Use the reverse-proxy address if one is in front (e.g. https://radio.example.com/stream)
STREAM_URL=http://your-server:8080/stream

# ── Icecast ───────────────────────────────────────────────────────────────────
ICECAST_SOURCE_PASSWORD=changeme
ICECAST_ADMIN_PASSWORD=changeme_admin

# ── Plex ──────────────────────────────────────────────────────────────────────
# PLEX_URL: address reachable FROM inside the container
PLEX_URL=http://192.168.1.x:32400
PLEX_TOKEN=your-plex-token

# ── AI DJ ─────────────────────────────────────────────────────────────────────
# Leave AI_MODEL blank to disable AI entirely.
#
# Option A — bundled Ollama (docker-compose --profile ai up):
#   OLLAMA_MODEL=qwen2.5:3b
#   AI_MODEL=ollama/qwen2.5:3b
#   AI_BASE_URL=http://ollama:11434
#
# Option B — external Ollama:
#   AI_MODEL=ollama/qwen2.5:3b
#   AI_BASE_URL=http://192.168.1.x:11434
#
# Option C — cloud (Anthropic, OpenAI, etc.):
#   AI_MODEL=anthropic/claude-haiku-4-5-20251001
#   AI_API_KEY=your-key-here
#
OLLAMA_MODEL=qwen2.5:3b
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=

# ── Last.fm ───────────────────────────────────────────────────────────────────
# Free read-only key from: https://www.last.fm/api/account/create
LASTFM_API_KEY=your-lastfm-api-key

# ── Matrix ────────────────────────────────────────────────────────────────────
MATRIX_HOMESERVER=https://matrix.example.com
MATRIX_TOKEN=syt_...
MATRIX_USER_ID=@radiobot:example.com
MATRIX_ROOM_ID=!roomid:example.com
# Comma-separated list of Matrix user IDs allowed to send commands
ALLOWED_MATRIX_USERS=@you:example.com

# ── Auth ──────────────────────────────────────────────────────────────────────
# HMAC key for session cookies. Auto-generated and persisted to /data/ if blank.
# Set explicitly if you want sessions to survive container recreation.
SESSION_SECRET=

# ── Internal (don't change) ───────────────────────────────────────────────────
LIQUIDSOAP_HOST=localhost
LIQUIDSOAP_PORT=1234
