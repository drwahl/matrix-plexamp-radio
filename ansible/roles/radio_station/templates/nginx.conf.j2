server {
    listen 80;

    root /app/web;
    index index.html;

    # Proxy public API endpoints to radio-service (same container, loopback)
    location /api/ {
        proxy_pass http://127.0.0.1:8081/api/;
        proxy_set_header Host $host;
    }

    # Proxy Icecast stream — buffering off is critical for live audio
    location /stream {
        proxy_pass http://127.0.0.1:8000{{ radio_station_stream_mount }};
        proxy_buffering off;
        proxy_read_timeout 3600s;
        proxy_set_header Host $host;
    }

    # Static web player
    location / {
        try_files $uri $uri/ /index.html;
    }
}
